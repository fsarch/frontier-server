{
  "name": "frontier-worker",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "concurrently \"npm run build:watch\" \"node --watch dist/main.js\"",
    "start:dev": "concurrently \"npm run build:watch\" \"node --watch dist/main.js\"",
    "start:local": "./scripts/start-local.zsh",
    "start:debug": "node --inspect-brk dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint --config .eslintrc.cjs \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest run --inspect-brk",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.0",
    "undici": "^7.16.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "@types/ws": "^8.5.18",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/ui": "^4.1.10",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10",
    "@vitest/ui": "^1.0.0"
  }
}
