{
  "name": "frontier-worker",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "concurrently \"npm run build:watch\" \"node --watch dist/main.js\"",
    "start:dev": "concurrently \"npm run build:watch\" \"node --watch dist/main.js\"",
    "start:local": "./scripts/start-local.zsh",
    "start:debug": "node --inspect-brk dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint --config .eslintrc.cjs \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest run --inspect-brk",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "reflect-metadata": "^0.2.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/ui": "^4.1.10",
    "concurrently": "^8.2.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.5",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
