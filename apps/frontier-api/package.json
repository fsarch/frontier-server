{
  "name": "frontier-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "fsarch-server build",
    "build:watch": "tsc -p tsconfig.json --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "fsarch-server start",
    "start:debug": "node --inspect-brk dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint --config .eslintrc.cjs \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "node --experimental-vm-modules -r jest/globals.js jest",
    "test:watch": "node --experimental-vm-modules -r jest/globals.js jest --watch",
    "test:cov": "node --experimental-vm-modules -r jest/globals.js jest --coverage",
    "test:debug": "node --inspect-brk --experimental-vm-modules -r jest/globals.js jest --runInBand",
    "test:e2e": "node --experimental-vm-modules -r jest/globals.js jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@fsarch/server": "^0.0.8",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-ws": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/typeorm": "^11.0.3",
    "@nestjs/websockets": "^11.1.28",
    "joi": "^18.2.3",
    "jose": "^6.2.3",
    "js-yaml": "^5.2.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "serialize-error": "^13.0.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "concurrently": "^8.2.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": ["ts-jest", { "useESM": true }]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "transformIgnorePatterns": [
      "node_modules/(?!(.*\\.(mjs|js)$))"
    ],
    "moduleNameMapper": {
      "^(\\..+)$": "<rootDir>/src/$1"
    }
  }
}
