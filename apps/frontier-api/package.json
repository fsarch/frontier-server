  "type": "module",
  "scripts": {
    "build": "fsarch-server build",
    "build:watch": "tsc -p tsconfig.json --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "fsarch-server start",
    "start:debug": "node --inspect-brk dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint --config .eslintrc.cjs \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
    "test:e2e": "vitest run --config ./vitest.e2e.config.ts"
  },
  "dependencies": {
    "@fsarch/server": "^0.0.8",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-ws": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/typeorm": "^11.0.3",
    "@nestjs/websockets": "^11.1.28",
    "joi": "^18.2.3",
    "jose": "^6.2.3",
    "js-yaml": "^5.2.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "serialize-error": "^13.0.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
